{
	"name": "musicd-frontend",
	"private": true,
	"type": "module",
	"main": "electron/dist/main.js",
	"author": "placeholder@example.com",
	"homepage": "https://github.com/1800alex/musicd",
	"description": "A music streaming web application built with Nuxt.js, featuring a responsive design, native audio support, and integration with Capacitor for mobile platforms and Electron for desktop.",
	"version": "0.0.1",
	"scripts": {
		"build": "nuxt build",
		"dev": "nuxt dev --dotenv .env.development",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"serve": "node .output/server/index.mjs",
		"clean": "nuxt cleanup",
		"prettier": "prettier --config .prettierrc -c . --write",
		"shell": "node",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:report": "playwright show-report",
		"cap:build": "nuxt generate && npx cap sync",
		"cap:sync": "npx cap sync",
		"cap:open:ios": "npx cap open ios",
		"cap:open:android": "npx cap open android",
		"cap:run:ios": "npx cap run ios",
		"cap:run:android": "npx cap run android",
		"electron:dev": "NODE_ENV=development nuxt generate && electron .",
		"electron:build": "tsc -p electron/tsconfig.json && tsc -p electron/tsconfig.preload.json && ELECTRON_BUILD=1 nuxt generate && electron-builder --publish never"
	},
	"dependencies": {
		"@capacitor/android": "^8.2.0",
		"@capacitor/app": "^8.0.1",
		"@capacitor/cli": "^8.2.0",
		"@capacitor/core": "^8.2.0",
		"@capacitor/haptics": "^8.0.1",
		"@capacitor/ios": "^8.2.0",
		"@fortawesome/fontawesome-svg-core": "^6.7.2",
		"@fortawesome/free-brands-svg-icons": "^6.7.2",
		"@fortawesome/free-solid-svg-icons": "^6.7.2",
		"@fortawesome/vue-fontawesome": "^3.0.8",
		"@mdi/js": "^7.4.47",
		"@nuxt/fonts": "^0.11.4",
		"@pinia/nuxt": "^0.11.2",
		"buefy": "^3.0.2",
		"bulma": "^1.0.4",
		"electron-serve": "^3.0.1",
		"eslint": "^9.22.0",
		"lodash-es": "^4.17.21",
		"nuxt": "^4.0.1",
		"pinia": "^3.0.3",
		"vue": "^3.5.18",
		"vue-component-type-helpers": "^3.0.4",
		"vue-router": "^4.5.1",
		"vue3-touch-events": "^5.0.15",
		"zxcvbn": "^4.4.2"
	},
	"devDependencies": {
		"@nuxt/eslint": "^1.7.1",
		"@playwright/test": "^1.58.2",
		"@steeringwaves/eslint-config": "^2.1.4",
		"@steeringwaves/prettier-config": "^1.0.2",
		"@types/lodash-es": "^4.17.12",
		"@types/node": "^22.16.5",
		"@types/zxcvbn": "^4.4.5",
		"electron": "^41.0.0",
		"electron-builder": "^26.8.1",
		"prettier": "^3.5.3",
		"sass-embedded": "^1.89.2",
		"typescript": "^5.8.3",
		"vue-tsc": "^3.0.4"
	},
	"packageManager": "yarn@4.8.1"
}
