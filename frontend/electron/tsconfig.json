{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"lib": ["ES2020"],
		"outDir": "./dist",
		"rootDir": ".",
		"resolveJsonModule": true,
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"declaration": true,
		"sourceMap": true
	},
	"include": ["main.ts"],
	"exclude": ["dist", "node_modules"]
}
